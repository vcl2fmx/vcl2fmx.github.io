      "conditions": "",
      "updatedAt": "2026-05-20T09:56:24.311Z"
    },
    {
      "id": "{9DD36119-1FD7-46F0-9E03-CB8F2D64F145}",
      "parentId": "",
      "title": "Appendix D. Glossary",
      "body": "# Appendix D. Glossary\r\n\r\n<table class=\"doc-table\">\r\n<tr><th>Term</th><th>Meaning</th></tr>\r\n<tr><td>VCL</td><td>Visual Component Library, Delphi's traditional Windows UI framework.</td></tr>\r\n<tr><td>FMX</td><td>FireMonkey, Delphi's multi-platform UI framework.</td></tr>\r\n<tr><td>DFM</td><td>A Delphi form definition file used by VCL projects.</td></tr>\r\n<tr><td>FMX form</td><td>The converted FireMonkey form file, typically emitted as .fmx.</td></tr>\r\n<tr><td>LiveBindings</td><td>The FMX binding model used for data-aware behavior.</td></tr>\r\n<tr><td>Global fix</td><td>A converter change that benefits multiple current or future projects, not just one output file.</td></tr>\r\n<tr><td>Mapping pack</td><td>Optional JSON file that adds transparent third-party component detection, conversion, preservation, or manual-review rules.</td></tr>\r\n</table>",
      "status": "Ready",
      "iconName": "auto",
      "owner": "Auto Import",
      "helpId": "IDH_APPENDIX_D_GLOSSARY",
      "language": "en-US",
      "tags": "imported,docx,troubleshooting,reference",
      "conditions": "",
      "updatedAt": "2026-05-20T09:56:24.311Z"
