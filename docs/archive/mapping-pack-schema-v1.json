{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcl2fmxconverter.local/schemas/mapping-pack-v1.json",
  "title": "VCL2FMXConverter Mapping Pack v1",
  "type": "object",
  "required": ["pack_name", "pack_id", "vendor", "version", "description", "mode", "rules"],
  "properties": {
    "pack_name": { "type": "string" },
    "pack_id": { "type": "string" },
    "vendor": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["conservative", "detection", "conversion"]
    },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "required": ["vcl_class", "action"],
      "properties": {
        "vcl_class": { "type": "string" },
        "fmx_class": { "type": "string" },
        "action": {
          "type": "string",
          "enum": ["convert", "partial", "manual_review", "detect_only", "preserve"]
        },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "probability": { "type": "integer", "minimum": 0, "maximum": 100 },
        "notes": { "type": "string" },
        "manual_review_reason": { "type": "string" },
        "vendor": { "type": "string" },
        "pack_name": { "type": "string" },
        "pack_version": { "type": "string" },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/property_map" }
        },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/event_map" }
        }
      }
    },
    "property_map": {
      "type": "object",
      "required": ["vcl", "fmx"],
      "properties": {
        "vcl": { "type": "string" },
        "fmx": { "type": "string" },
        "needs_transform": { "type": "boolean" },
        "transformer": { "type": "string" }
      }
    },
    "event_map": {
      "type": "object",
      "required": ["vcl", "fmx"],
      "properties": {
        "vcl": { "type": "string" },
        "fmx": { "type": "string" },
        "signature_match": { "type": "boolean" }
      }
    }
  }
}
